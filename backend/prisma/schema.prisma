// =====================================================
// 伊春有事儿说 - Prisma Schema
// Database: MySQL 8
// Generator: Prisma Client
// =====================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// =====================================================
// 用户表
// =====================================================
model User {
  id          BigInt    @id @default(autoincrement())
  phone       String    @unique @db.VarChar(20)
  password    String?   @map("password") @db.VarChar(100)
  nickname    String    @default("") @db.VarChar(50)
  avatar      String?   @db.VarChar(255)
  gender      Int       @default(0) @db.TinyInt
  bio         String?   @db.VarChar(255)
  status      Int       @default(0) @db.TinyInt
  role        String    @default("user") @db.VarChar(20)
  lastLoginAt DateTime? @map("last_login_at")
  // T-001: 软删除 + 审计字段
  deletedAt   DateTime? @map("deleted_at") @db.DateTime(3)
  createdBy   BigInt?   @map("created_by")
  updatedBy   BigInt?   @map("updated_by")
  deletedBy   BigInt?   @map("deleted_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // 关联
  posts            Post[]
  favorites        Favorite[]
  comments         Comment[]
  reportsMade      Report[]         @relation("ReportByUser")
  reportsHandled   Report[]         @relation("ReportHandledBy")
  companiesCreated Company[]        @relation("CompanyCreator")
  resume           Resume?
  applications     JobApplication[] @relation("ApplicationUser")
  auditLogs        AuditLog[]
  loginLogs        LoginLog[]
  messagesSent     Message[]        @relation("MessageSender")
  messagesReceived Message[]        @relation("MessageReceiver")
  userRoles        UserRole[]       @relation("UserRoles")
  // T-007: 通知系统
  notifications    Notification[]
  notificationSettings UserNotificationSetting[]
  deviceTokens     DeviceToken[]

  @@index([status, createdAt])
  @@index([role, status])
  @@index([deletedAt])
  @@map("users")
}

// =====================================================
// 分类表（树形）
// =====================================================
model Category {
  id        BigInt    @id @default(autoincrement())
  parentId  BigInt?   @map("parent_id")
  code      String    @map("code") @db.VarChar(30)
  name      String    @db.VarChar(50)
  icon      String?   @db.VarChar(255)
  sortOrder Int       @default(0) @map("sort_order")
  status    Int       @default(1) @db.TinyInt
  // T-001: 软删除 + 审计字段
  deletedAt DateTime? @map("deleted_at") @db.DateTime(3)
  createdBy BigInt?   @map("created_by")
  updatedBy BigInt?   @map("updated_by")
  deletedBy BigInt?   @map("deleted_by")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // 自关联
  parent   Category?  @relation("CategoryToParent", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children Category[] @relation("CategoryToParent")

  // 关联
  posts Post[]

  @@index([parentId, sortOrder])
  @@index([code])
  @@index([deletedAt])
  @@map("categories")
}

// =====================================================
// 信息主表（4 大模块共用）
// =====================================================
model Post {
  id               BigInt    @id @default(autoincrement())
  userId           BigInt    @map("user_id")
  categoryId       BigInt    @map("category_id")
  areaId           BigInt?   @map("area_id")
  type             String    @db.VarChar(20)
  title            String    @db.VarChar(100)
  description      String    @db.Text
  price            Decimal   @default(0) @db.Decimal(10, 2)
  priceUnit        String?   @map("price_unit") @db.VarChar(20)
  contactName      String?   @map("contact_name") @db.VarChar(50)
  contactPhone     String?   @map("contact_phone") @db.VarChar(20)
  contactWechat    String?   @map("contact_wechat") @db.VarChar(50)
  status           String    @default("draft") @db.VarChar(20)
  auditStatus      String    @default("pending") @map("audit_status") @db.VarChar(20)
  auditReason      String?   @map("audit_reason") @db.VarChar(255)
  tags             Json?     @map("tags")
  viewCount        Int       @default(0) @map("view_count")
  favoriteCount    Int       @default(0) @map("favorite_count")
  commentCount     Int       @default(0) @map("comment_count")
  // Phase 2: AI 智能发布 - SEO + 质量分 + 商业识别
  seoMeta          Json?     @map("seo_meta")
  qualityScore     Int?      @map("quality_score")
  seoMetaUpdatedAt DateTime? @map("seo_meta_updated_at")
  isBusiness       Boolean?  @map("is_business")
  businessType     String?   @map("business_type") @db.VarChar(32)
  boostExpiresAt   DateTime? @map("boost_expires_at")
  // T-001: 软删除 + 审计字段
  deletedAt        DateTime? @map("deleted_at") @db.DateTime(3)
  createdBy        BigInt?   @map("created_by")
  updatedBy        BigInt?   @map("updated_by")
  deletedBy        BigInt?   @map("deleted_by")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // 关联
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  area        Area?           @relation(fields: [areaId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  images      PostImage[]
  favoritedBy Favorite[]
  comments    Comment[]
  reports     Report[]        @relation("ReportForPost")
  house       PostHouse?
  secondhand  PostSecondhand?
  lifebiz     PostLifebiz?
  job         PostJob?
  postTags    PostTag[]

  @@index([userId])
  @@index([categoryId, status, createdAt])
  @@index([areaId, status, createdAt])
  @@index([type, status, createdAt])
  @@index([auditStatus, createdAt])
  @@index([title])
  // Phase 2 索引: SEO 重生成 / 质量分排序 / 商业识别 / 置顶过期
  @@index([seoMetaUpdatedAt])
  @@index([qualityScore])
  @@index([isBusiness, businessType])
  @@index([boostExpiresAt])
  // 全文索引（MySQL FULLTEXT，V1 简化版用空格分词；中文支持有限，V1.1 接 ES）
  // 注：FULLTEXT 索引需要在迁移后用 SQL 单独添加（Prisma 不支持原生 FULLTEXT）
  @@index([deletedAt])
  @@map("posts")
}

// =====================================================
// 区域表（树形：市 → 区县 → 街道）
// =====================================================
model Area {
  id        BigInt    @id @default(autoincrement())
  parentId  BigInt?   @map("parent_id")
  name      String    @db.VarChar(50)
  level     Int       @default(1) @db.TinyInt
  adCode    String?   @map("ad_code") @db.VarChar(20)
  sortOrder Int       @default(0) @map("sort_order")
  // T-001: 软删除 + 审计字段
  deletedAt DateTime? @map("deleted_at") @db.DateTime(3)
  createdBy BigInt?   @map("created_by")
  updatedBy BigInt?   @map("updated_by")
  deletedBy BigInt?   @map("deleted_by")
  createdAt DateTime  @default(now()) @map("created_at")

  // 自关联
  parent   Area?  @relation("AreaToParent", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children Area[] @relation("AreaToParent")

  // 反向关联
  posts Post[]

  @@index([parentId, sortOrder])
  @@index([adCode])
  @@index([deletedAt])
  @@map("areas")
}

// =====================================================
// 信息图片（V1 预留，1:N）
// V1.3 阶段把上传功能完整接入 post 发布流程
// =====================================================
model PostImage {
  id        BigInt    @id @default(autoincrement())
  postId    BigInt    @map("post_id")
  url       String    @db.VarChar(500)
  width     Int?
  height    Int?
  size      Int?      @db.Int
  mimeType  String?   @map("mime_type") @db.VarChar(50)
  sortOrder Int       @default(0) @map("sort_order")
  isCover   Int       @default(0) @map("is_cover") @db.TinyInt
  // T-001: 软删除 + 审计字段
  deletedAt DateTime? @map("deleted_at") @db.DateTime(3)
  createdBy BigInt?   @map("created_by")
  updatedBy BigInt?   @map("updated_by")
  deletedBy BigInt?   @map("deleted_by")
  createdAt DateTime  @default(now()) @map("created_at")

  // 关联
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, sortOrder])
  @@index([deletedAt])
  @@map("post_images")
}

// =====================================================
// 收藏（用户 ↔ 信息）
// =====================================================
model Favorite {
  id        BigInt    @id @default(autoincrement())
  userId    BigInt    @map("user_id")
  postId    BigInt    @map("post_id")
  // T-001: 软删除 + 审计字段
  deletedAt DateTime? @map("deleted_at") @db.DateTime(3)
  createdBy BigInt?   @map("created_by")
  updatedBy BigInt?   @map("updated_by")
  deletedBy BigInt?   @map("deleted_by")
  createdAt DateTime  @default(now()) @map("created_at")

  // 关联
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId, createdAt])
  @@index([deletedAt])
  @@map("favorites")
}

// =====================================================
// 留言/评论（自关联：顶级留言 + 回复）
// =====================================================
model Comment {
  id        BigInt    @id @default(autoincrement())
  userId    BigInt    @map("user_id")
  postId    BigInt    @map("post_id")
  parentId  BigInt?   @map("parent_id")
  content   String    @db.VarChar(500)
  status    Int       @default(0) @db.TinyInt
  // T-001: 软删除 + 审计字段
  deletedAt DateTime? @map("deleted_at") @db.DateTime(3)
  createdBy BigInt?   @map("created_by")
  updatedBy BigInt?   @map("updated_by")
  deletedBy BigInt?   @map("deleted_by")
  createdAt DateTime  @default(now()) @map("created_at")

  // 关联
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  post     Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent   Comment?  @relation("CommentToParent", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children Comment[] @relation("CommentToParent")

  @@index([postId, createdAt])
  @@index([userId])
  @@index([deletedAt])
  @@map("comments")
}

// =====================================================
// 举报（用户对信息）
// =====================================================
model Report {
  id          BigInt    @id @default(autoincrement())
  userId      BigInt    @map("user_id")
  postId      BigInt    @map("post_id")
  reason      String    @db.VarChar(50)
  description String?   @db.VarChar(500)
  status      String    @default("pending") @db.VarChar(20)
  handledBy   BigInt?   @map("handled_by")
  handledAt   DateTime? @map("handled_at")
  // T-001: 软删除 + 审计字段
  deletedAt   DateTime? @map("deleted_at") @db.DateTime(3)
  createdBy   BigInt?   @map("created_by")
  updatedBy   BigInt?   @map("updated_by")
  deletedBy   BigInt?   @map("deleted_by")
  createdAt   DateTime  @default(now()) @map("created_at")

  // 关联
  user    User  @relation("ReportByUser", fields: [userId], references: [id], onDelete: Cascade)
  post    Post  @relation("ReportForPost", fields: [postId], references: [id], onDelete: Cascade)
  handler User? @relation("ReportHandledBy", fields: [handledBy], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([postId])
  @@index([status, createdAt])
  @@index([userId])
  @@index([deletedAt])
  @@map("reports")
}

// =====================================================
// 房屋详情（1:1 关联 posts）
// =====================================================
model PostHouse {
  id            BigInt    @id @default(autoincrement())
  postId        BigInt    @unique @map("post_id")
  rentalType    String    @map("rental_type") @db.VarChar(20)
  propertyType  String    @map("property_type") @db.VarChar(20)
  decoration    String?   @db.VarChar(20)
  areaSqm       Decimal?  @map("area_sqm") @db.Decimal(8, 2)
  rooms         Int?      @db.TinyInt
  livingRooms   Int?      @map("living_rooms") @db.TinyInt
  bathrooms     Int?      @db.TinyInt
  floorInfo     String?   @map("floor_info") @db.VarChar(50)
  orientation   String?   @db.VarChar(50)
  buildingYear  Int?      @map("building_year")
  communityName String?   @map("community_name") @db.VarChar(100)
  address       String?   @db.VarChar(255)
  longitude     Decimal?  @db.Decimal(10, 6)
  latitude      Decimal?  @db.Decimal(10, 6)
  facilities    Json?
  // T-001: 软删除 + 审计字段
  deletedAt     DateTime? @map("deleted_at") @db.DateTime(3)
  createdBy     BigInt?   @map("created_by")
  updatedBy     BigInt?   @map("updated_by")
  deletedBy     BigInt?   @map("deleted_by")

  // 关联
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([rentalType])
  @@index([propertyType])
  @@index([areaSqm])
  @@index([rentalType, propertyType, areaSqm])
  @@index([deletedAt])
  @@map("post_houses")
}

// =====================================================
// 二手详情（1:1 关联 posts）
// =====================================================
model PostSecondhand {
  id            BigInt    @id @default(autoincrement())
  postId        BigInt    @unique @map("post_id")
  categoryName  String    @map("category_name") @db.VarChar(50)
  condition     String    @db.VarChar(20)
  originalPrice Decimal?  @map("original_price") @db.Decimal(10, 2)
  tradeMethod   String?   @map("trade_method") @db.VarChar(30)
  usageDuration String?   @map("usage_duration") @db.VarChar(50)
  // T-001: 软删除 + 审计字段
  deletedAt     DateTime? @map("deleted_at") @db.DateTime(3)
  createdBy     BigInt?   @map("created_by")
  updatedBy     BigInt?   @map("updated_by")
  deletedBy     BigInt?   @map("deleted_by")

  // 关联
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([categoryName])
  @@index([condition])
  @@index([deletedAt])
  @@map("post_secondhands")
}

// =====================================================
// 便民详情（1:1 关联 posts）
// =====================================================
model PostLifebiz {
  id             BigInt    @id @default(autoincrement())
  postId         BigInt    @unique @map("post_id")
  subCategory    String    @map("sub_category") @db.VarChar(50)
  serviceType    String    @map("service_type") @db.VarChar(20)
  price          Decimal?  @db.Decimal(10, 2)
  priceText      String?   @map("price_text") @db.VarChar(50)
  validityPeriod String?   @map("validity_period") @db.VarChar(20)
  expireAt       DateTime? @map("expire_at")
  // T-001: 软删除 + 审计字段
  deletedAt      DateTime? @map("deleted_at") @db.DateTime(3)
  createdBy      BigInt?   @map("created_by")
  updatedBy      BigInt?   @map("updated_by")
  deletedBy      BigInt?   @map("deleted_by")

  // 关联
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([subCategory])
  @@index([serviceType])
  @@index([expireAt])
  @@index([deletedAt])
  @@map("post_lifebizs")
}

// =====================================================
// 公司表（独立于 posts）
// =====================================================
model Company {
  id            BigInt    @id @default(autoincrement())
  creatorUserId BigInt    @map("creator_user_id")
  name          String    @db.VarChar(100)
  logo          String?   @db.VarChar(255)
  industry      String?   @db.VarChar(50)
  scale         String?   @db.VarChar(30)
  nature        String?   @db.VarChar(30)
  address       String?   @db.VarChar(255)
  description   String?   @db.Text
  verified      Int       @default(0) @db.TinyInt
  // T-001: 软删除 + 审计字段
  deletedAt     DateTime? @map("deleted_at") @db.DateTime(3)
  createdBy     BigInt?   @map("created_by")
  updatedBy     BigInt?   @map("updated_by")
  deletedBy     BigInt?   @map("deleted_by")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // 关联
  creator User      @relation("CompanyCreator", fields: [creatorUserId], references: [id], onDelete: Cascade)
  jobs    PostJob[]

  @@index([creatorUserId])
  @@index([name])
  @@index([verified])
  @@index([deletedAt])
  @@map("companies")
}

// =====================================================
// 招聘详情（1:1 关联 posts + N:1 关联 companies）
// =====================================================
model PostJob {
  id           BigInt    @id @default(autoincrement())
  postId       BigInt    @unique @map("post_id")
  companyId    BigInt    @map("company_id")
  jobType      String    @map("job_type") @db.VarChar(20)
  salaryMin    Decimal?  @map("salary_min") @db.Decimal(10, 2)
  salaryMax    Decimal?  @map("salary_max") @db.Decimal(10, 2)
  salaryUnit   String?   @map("salary_unit") @db.VarChar(20)
  education    String?   @db.VarChar(20)
  experience   String?   @db.VarChar(20)
  industry     String?   @db.VarChar(50)
  welfare      Json?
  recruitCount Int       @default(1) @map("recruit_count")
  workCity     String?   @map("work_city") @db.VarChar(50)
  workAddress  String?   @map("work_address") @db.VarChar(255)
  // T-001: 软删除 + 审计字段
  deletedAt    DateTime? @map("deleted_at") @db.DateTime(3)
  createdBy    BigInt?   @map("created_by")
  updatedBy    BigInt?   @map("updated_by")
  deletedBy    BigInt?   @map("deleted_by")

  // 关联
  post         Post             @relation(fields: [postId], references: [id], onDelete: Cascade)
  company      Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  applications JobApplication[]

  @@index([companyId])
  @@index([salaryMin, salaryMax])
  @@index([deletedAt])
  @@map("post_jobs")
}

// =====================================================
// 简历（1:1 关联 user）
// =====================================================
model Resume {
  id               BigInt    @id @default(autoincrement())
  userId           BigInt    @unique @map("user_id")
  name             String    @db.VarChar(50)
  gender           Int       @default(0) @db.TinyInt
  age              Int?
  phone            String?   @db.VarChar(20)
  email            String?   @db.VarChar(100)
  education        String?   @db.VarChar(20)
  experience       String?   @db.VarChar(20)
  expectedPosition String?   @map("expected_position") @db.VarChar(100)
  expectedSalary   Decimal?  @map("expected_salary") @db.Decimal(10, 2)
  expectedCity     String?   @map("expected_city") @db.VarChar(50)
  selfIntro        String?   @map("self_intro") @db.Text
  isPublic         Int       @default(0) @map("is_public") @db.TinyInt
  // T-001: 软删除 + 审计字段
  deletedAt        DateTime? @map("deleted_at") @db.DateTime(3)
  createdBy        BigInt?   @map("created_by")
  updatedBy        BigInt?   @map("updated_by")
  deletedBy        BigInt?   @map("deleted_by")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // 关联
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications JobApplication[]

  @@index([deletedAt])
  @@map("resumes")
}

// =====================================================
// 投递记录
// =====================================================
model JobApplication {
  id          BigInt    @id @default(autoincrement())
  postJobId   BigInt    @map("post_job_id")
  resumeId    BigInt    @map("resume_id")
  userId      BigInt    @map("user_id")
  coverLetter String?   @db.VarChar(500)
  status      String    @default("已投递") @db.VarChar(20)
  // T-001: 软删除 + 审计字段
  deletedAt   DateTime? @map("deleted_at") @db.DateTime(3)
  createdBy   BigInt?   @map("created_by")
  updatedBy   BigInt?   @map("updated_by")
  deletedBy   BigInt?   @map("deleted_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // 关联
  postJob PostJob @relation(fields: [postJobId], references: [id], onDelete: Cascade)
  resume  Resume  @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  user    User    @relation("ApplicationUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postJobId, resumeId])
  @@index([userId, createdAt])
  @@index([deletedAt])
  @@map("job_applications")
}

// =====================================================
// 站内信（MUST-17）
// =====================================================
model Message {
  id         BigInt    @id @default(autoincrement())
  senderId   BigInt    @map("sender_id")
  receiverId BigInt    @map("receiver_id")
  content    String    @db.VarChar(1000)
  isRead     Int       @default(0) @map("is_read") @db.TinyInt
  readAt     DateTime? @map("read_at")
  // T-001: 软删除 + 审计字段
  deletedAt  DateTime? @map("deleted_at") @db.DateTime(3)
  createdBy  BigInt?   @map("created_by")
  updatedBy  BigInt?   @map("updated_by")
  deletedBy  BigInt?   @map("deleted_by")
  createdAt  DateTime  @default(now()) @map("created_at")

  sender   User @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([receiverId, isRead, createdAt])
  @@index([senderId, createdAt])
  @@index([deletedAt])
  @@map("messages")
}

// =====================================================
// 操作审计日志（MUST-16）
// =====================================================
model AuditLog {
  id             BigInt   @id @default(autoincrement())
  adminUserId    BigInt   @map("admin_user_id")
  module         String   @db.VarChar(50)
  action         String   @db.VarChar(50)
  targetType     String   @map("target_type") @db.VarChar(30)
  targetId       BigInt?  @map("target_id")
  reason         String?  @db.VarChar(500)
  metadata       Json?
  // T-005: 请求上下文 + 变更快照
  beforeSnapshot Json?    @map("before_snapshot")
  afterSnapshot  Json?    @map("after_snapshot")
  requestId      String?  @map("request_id") @db.VarChar(64)
  ip             String?  @db.VarChar(45)
  userAgent      String?  @map("user_agent") @db.VarChar(500)
  createdAt      DateTime @default(now()) @map("created_at")

  admin User @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId, createdAt])
  @@index([module, action, createdAt])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

// =====================================================
// 登录日志（MUST-16）
// =====================================================
model LoginLog {
  id         BigInt   @id @default(autoincrement())
  userId     BigInt   @map("user_id")
  ip         String?  @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.VarChar(500)
  device     String?  @db.VarChar(100)
  status     String   @default("success") @db.VarChar(20)
  failReason String?  @map("fail_reason") @db.VarChar(100)
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([ip, createdAt])
  @@map("login_logs")
}

// =====================================================
// 浏览日志（MUST-16，浏览量去重 + UV 统计基础）
// 注：userId 可空（未登录用户也可浏览），故不与 User 建反向关系
// =====================================================
model ViewLog {
  id        BigInt   @id @default(autoincrement())
  postId    BigInt   @map("post_id")
  userId    BigInt?  @map("user_id")
  ip        String?  @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([postId, createdAt])
  @@index([userId, createdAt])
  @@index([ip, createdAt])
  @@map("view_logs")
}

// =====================================================
// 短信验证码（持久化留痕 + 查码面板）
// =====================================================
model SmsCode {
  id         BigInt    @id @default(autoincrement())
  phone      String    @db.VarChar(20)
  code       String    @db.VarChar(10)
  purpose    String    @default("login") @db.VarChar(32)
  ip         String?   @db.VarChar(45)
  consumed   Boolean   @default(false)
  attempts   Int       @default(0)
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  consumedAt DateTime? @map("consumed_at")

  @@index([phone, purpose, createdAt])
  @@index([ip, createdAt])
  @@index([expiresAt])
  @@map("sms_codes")
}

// =====================================================
// 公告系统（SHOULD-30）
// =====================================================
model Announcement {
  id        BigInt    @id @default(autoincrement())
  title     String    @db.VarChar(100)
  content   String    @db.Text
  status    Int       @default(1) @db.TinyInt
  priority  Int       @default(0) @db.TinyInt
  startsAt  DateTime? @map("starts_at")
  endsAt    DateTime? @map("ends_at")
  createdBy BigInt    @map("created_by")
  // T-001: 软删除 + 审计字段
  deletedAt DateTime? @map("deleted_at") @db.DateTime(3)
  updatedBy BigInt?   @map("updated_by")
  deletedBy BigInt?   @map("deleted_by")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([status, priority, createdAt])
  @@index([startsAt, endsAt])
  @@index([deletedAt])
  @@map("announcements")
}

// =====================================================
// 首页 / 列表页 Banner 运营位（首页轮播 / 分类页 banner）
// =====================================================
model Banner {
  id         BigInt    @id @default(autoincrement())
  title      String    @db.VarChar(100)
  imageUrl   String    @map("image_url") @db.VarChar(500)
  linkType   String    @default("url") @map("link_type") @db.VarChar(20)
  linkTarget String    @default("") @map("link_target") @db.VarChar(500)
  position   String    @default("home_top") @db.VarChar(30)
  sortOrder  Int       @default(0) @map("sort_order")
  status     Int       @default(1) @db.TinyInt
  startsAt   DateTime? @map("starts_at")
  endsAt     DateTime? @map("ends_at")
  createdBy  BigInt    @map("created_by")
  // T-001: 软删除 + 审计字段
  deletedAt  DateTime? @map("deleted_at") @db.DateTime(3)
  updatedBy  BigInt?   @map("updated_by")
  deletedBy  BigInt?   @map("deleted_by")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([position, status, sortOrder])
  @@index([startsAt, endsAt])
  @@index([deletedAt])
  @@map("banners")
}

// =====================================================
// AI 智能发布 (Phase 1: extract / suggest-title) 调用审计
// =====================================================
/// AI 调用审计表 (Phase 1: extract / suggest-title)
model AiUsageLog {
  id           BigInt   @id @default(autoincrement())
  userId       BigInt?  @map("user_id")
  kind         String   @db.VarChar(32) // 'extract' | 'suggest-title'
  model        String   @db.VarChar(64) // 'claude-haiku-4-5-20251001'
  inputTokens  Int      @map("input_tokens")
  outputTokens Int      @map("output_tokens")
  costUsd      Decimal  @map("cost_usd") @db.Decimal(10, 6)
  latencyMs    Int      @map("latency_ms")
  cached       Boolean  @default(false)
  success      Boolean  @default(true)
  errorCode    String?  @map("error_code") @db.VarChar(64)
  inputHash    String?  @map("input_hash") @db.VarChar(64) // sha256(rawText), 用于审计去重
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([kind, createdAt])
  @@map("ai_usage_logs")
}

// =====================================================
// Sitemap 推送日志 (Phase 2: 主动推送收录面板)
// 用于记录 baidu / sogou / 360 的推送结果
// =====================================================
model SitemapPushLog {
  id       BigInt   @id @default(autoincrement())
  target   String   @db.VarChar(16) // 'baidu' | 'sogou' | '360'
  postIds  Json // 推送的 post id 列表
  status   String   @db.VarChar(16) // 'success' | 'failed' | 'partial'
  response String?  @db.Text // 推送接口原始响应
  pushedAt DateTime @default(now()) @map("pushed_at")

  @@index([target, pushedAt])
  @@map("sitemap_push_logs")
}

// =====================================================
// T-002 RBAC — 角色 / 权限 / 关联表
// 与 User.role 字符串字段并存（兼容期 1 个月，T-003 阶段统一切换）
// =====================================================

// 角色（admin 维度，区别于 User.role 字符串）
model Role {
  id          BigInt    @id @default(autoincrement())
  code        String    @unique @db.VarChar(50) // 'super_admin' | 'content_auditor' | ...
  name        String    @db.VarChar(50)
  description String?   @db.VarChar(255)
  isSystem    Boolean   @default(false) // 系统预置不可删
  sortOrder   Int       @default(0) // 展示顺序
  status      Int       @default(1) @db.TinyInt // 1=启用 0=停用
  // T-001 软删字段
  deletedAt   DateTime? @map("deleted_at") @db.DateTime(3)
  createdBy   BigInt?   @map("created_by")
  updatedBy   BigInt?   @map("updated_by")
  deletedBy   BigInt?   @map("deleted_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // 关联
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@index([status, sortOrder])
  @@index([deletedAt])
  @@map("roles")
}

// 权限码（粒度到具体操作）
model Permission {
  id          BigInt    @id @default(autoincrement())
  code        String    @unique @db.VarChar(100) // 'post.audit.pass' | 'user.ban' | ...
  module      String    @db.VarChar(30) // 'post' | 'user' | 'role' | ...
  action      String    @db.VarChar(30) // 'audit.pass' | 'ban' | 'create' | ...
  name        String    @db.VarChar(100)
  description String?   @db.VarChar(255)
  // T-001
  deletedAt   DateTime? @map("deleted_at") @db.DateTime(3)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // 关联
  rolePermissions RolePermission[]

  @@index([module, action])
  @@index([deletedAt])
  @@map("permissions")
}

// 用户 ↔ 角色 (N:N)
model UserRole {
  id        BigInt    @id @default(autoincrement())
  userId    BigInt    @map("user_id")
  roleId    BigInt    @map("role_id")
  grantedBy BigInt?   @map("granted_by") // 哪个 admin 分配的
  expiresAt DateTime? @map("expires_at") // 临时授权到期
  // T-001
  deletedAt DateTime? @map("deleted_at") @db.DateTime(3)
  createdBy BigInt?   @map("created_by")
  updatedBy BigInt?   @map("updated_by")
  deletedBy BigInt?   @map("deleted_by")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // 关联
  user User @relation("UserRoles", fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId]) // 防重复分配
  @@index([userId, createdAt])
  @@index([roleId])
  @@index([deletedAt])
  @@map("user_roles")
}

// 角色 ↔ 权限 (N:N)
model RolePermission {
  id           BigInt    @id @default(autoincrement())
  roleId       BigInt    @map("role_id")
  permissionId BigInt    @map("permission_id")
  // T-001
  deletedAt    DateTime? @map("deleted_at") @db.DateTime(3)
  createdBy    BigInt?   @map("created_by")
  updatedBy    BigInt?   @map("updated_by")
  deletedBy    BigInt?   @map("deleted_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // 关联
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@index([deletedAt])
  @@map("role_permissions")
}

// =====================================================
// T-007: 通知系统
// =====================================================

/// 通知模板（admin 可编辑；含变量占位符 {{userName}}）
model NotificationTemplate {
  id         BigInt   @id @default(autoincrement())
  /// 事件 code：comment / audit / order / auth / system / appeal / follow / invite
  event      String   @db.VarChar(50)
  /// 渠道：site（站内信）/ email / sms / push
  channel    String   @db.VarChar(20)
  /// 模板 key（unique within event+channel）
  key        String   @db.VarChar(50)
  title      String   @db.VarChar(200)
  body       String   @db.Text
  /// 变量定义（JSON: [{key, label, required}])
  variables  Json?
  /// 是否启用
  enabled    Boolean  @default(true)
  /// 默认优先级 1-5（5 最高）
  priority   Int      @default(3)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")
  createdBy  BigInt?  @map("created_by")
  updatedBy  BigInt?  @map("updated_by")
  deletedBy  BigInt?  @map("deleted_by")

  @@unique([event, channel, key], map: "uniq_event_channel_key")
  @@index([event, channel])
  @@index([deletedAt])
  @@map("notification_templates")
}

/// 用户通知（写库即发）
model Notification {
  id          BigInt   @id @default(autoincrement())
  userId      BigInt   @map("user_id")
  /// 事件 code（8 类）
  event       String   @db.VarChar(50)
  /// 渠道（默认 site）
  channel     String   @default("site") @db.VarChar(20)
  title       String   @db.VarChar(200)
  body        String   @db.Text
  /// 关联资源（JSON: {type, id, url}）可空
  payload     Json?
  /// 1-5 优先级
  priority    Int      @default(3)
  /// 已读时间
  readAt      DateTime? @map("read_at")
  createdAt   DateTime @default(now()) @map("created_at")
  /// T-001: 软删（用户主动删除通知）
  deletedAt   DateTime? @map("deleted_at")
  deletedBy   BigInt? @map("deleted_by")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@index([userId, createdAt])
  @@index([event, createdAt])
  @@index([deletedAt])
  @@map("notifications")
}

/// 用户通知偏好（按 event 维度开关）
model UserNotificationSetting {
  id         BigInt   @id @default(autoincrement())
  userId     BigInt   @map("user_id")
  /// event code
  event      String   @db.VarChar(50)
  /// 是否启用该类通知（默认 true）
  enabled    Boolean  @default(true)
  /// 静默时段（JSON: {start: "22:00", end: "08:00", timezone: "Asia/Shanghai"}）可空
  quietHours Json?    @map("quiet_hours")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, event], map: "uniq_user_event")
  @@index([userId])
  @@map("user_notification_settings")
}

/// 推送设备 Token（V1.1 用于推送通知，先建表）
model DeviceToken {
  id         BigInt   @id @default(autoincrement())
  userId     BigInt   @map("user_id")
  /// 平台：ios / android / web
  platform   String   @db.VarChar(20)
  /// 推送 token（FCM / APNs / Web Push）
  token      String   @db.VarChar(500)
  /// 设备 ID（用于去重 / 注销）
  deviceId   String?  @map("device_id") @db.VarChar(200)
  /// 最后活跃时间
  lastSeenAt DateTime @default(now()) @map("last_seen_at")
  createdAt  DateTime @default(now()) @map("created_at")
  /// T-001: 软删（注销设备）
  deletedAt  DateTime? @map("deleted_at")
  deletedBy  BigInt? @map("deleted_by")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, token], map: "uniq_user_token")
  @@index([userId])
  @@index([deletedAt])
  @@map("device_tokens")
}

// =====================================================
// T-013: 标签系统 — Tag / PostTag 关联表
// =====================================================

/// 标签字典（管理员后台维护 + 用户发布可选）
/// slug: URL 友好的英文标识（必填 unique）
/// name: 中文展示名
/// description: 标签描述（SEO + 详情页用）
/// useCount: 该标签关联的 PostTag 数（冗余字段，事务内维护）
/// isHot: 是否为热门标签（首页/侧栏展示）
/// sortOrder: 排序权重（asc，数值小排前）
model Tag {
  id          BigInt    @id @default(autoincrement())
  /// slug：URL 友好（如 shanlin / xueshan / bi-shu-fang）
  slug        String    @unique @db.VarChar(50)
  /// 中文名（如 "山林特产"）
  name        String    @db.VarChar(50)
  /// 标签描述（详情页 + SEO description）
  description String?   @db.VarChar(500)
  /// 关联的 PostTag 数（冗余，写入时事务内维护）
  useCount    Int       @default(0) @map("use_count")
  /// 是否热门标签（首页"热门标签云"用）
  isHot       Boolean   @default(false) @map("is_hot")
  /// 排序权重（asc；同 useCount 时按 sortOrder 升序，再按 id）
  sortOrder   Int       @default(0) @map("sort_order")
  createdBy   BigInt?   @map("created_by")
  updatedBy   BigInt?   @map("updated_by")
  deletedBy   BigInt?   @map("deleted_by")
  deletedAt   DateTime? @map("deleted_at") @db.DateTime(3)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  postTags PostTag[]

  @@index([useCount])
  @@index([isHot])
  @@index([deletedAt])
  @@map("tags")
}

/// 帖子-标签多对多关联
/// unique 约束防止同一帖子重复打同一标签
model PostTag {
  id        BigInt   @id @default(autoincrement())
  postId    BigInt   @map("post_id")
  tagId     BigInt   @map("tag_id")
  createdAt DateTime @default(now()) @map("created_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([postId, tagId], map: "uniq_post_tag")
  @@index([postId])
  @@index([tagId])
  @@map("post_tags")
}
