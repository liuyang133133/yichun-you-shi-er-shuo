# 应用
NODE_ENV=development
PORT=3001

# 数据库（Docker 容器内部用 mysql:3306；本机访问用 localhost:3307 避免和本地 MySQL 5.7 冲突）
# ⚠️ MySQL 密码必须使用强随机值（建议 `openssl rand -hex 16`），并同步修改：
#   1. docker-compose.yml 中 MYSQL_ROOT_PASSWORD / MYSQL_PASSWORD
#   2. backend/.env 中 DATABASE_URL
DATABASE_URL="mysql://yichun:<GENERATE_WITH_openssl_rand_hex_16>@localhost:3307/yichun_db?charset=utf8mb4&timezone=+08:00"

# Redis
REDIS_URL=redis://localhost:6379

# JWT
# ⚠️ JWT_SECRET 必须 ≥ 32 字符强随机（`openssl rand -base64 48`），启动期会强校验
# V1 启动失败提示：JWT_SECRET must be at least 32 characters
JWT_SECRET=<GENERATE_WITH_openssl_rand_base64_48>
JWT_EXPIRES_IN=7d

# CORS（生产环境必须白名单，逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# SHOULD-9: 人机验证（CAPTCHA）
# provider: none | turnstile
#   none     — dev/test 环境，开发期不验证（生产环境强制视为 turnstile）
#   turnstile — Cloudflare Turnstile 无感验证（生产环境推荐）
CAPTCHA_PROVIDER=none
# Turnstile 服务端密钥（https://dash.cloudflare.com → Turnstile → Sitekey）
# ⚠️ 仅服务端用，不要泄露到前端
TURNSTILE_SECRET=
# Turnstile 前端 Sitekey（公开，会暴露到前端 JS）
TURNSTILE_SITE_KEY=

# AI 智能发布 (Phase 1)
# AI_PROVIDER: 'glm' (免费, 智谱) or 'claude' (付费, Anthropic)
AI_PROVIDER=glm

# --- 智谱 GLM (免费, OpenAI 兼容) ---
# API key 从 https://bigmodel.cn/ 获取
GLM_API_KEY=your-zhipu-api-key-here
GLM_MODEL=glm-4-air
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# 可选: SOCKS5 代理 (境内容易用到). 例 socks5://127.0.0.1:10808
# GLM_PROXY_URL=

# --- Claude (Anthropic, 付费) ---
# 启用: AI_PROVIDER=claude
# API key 从 https://console.anthropic.com/ 获取
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
