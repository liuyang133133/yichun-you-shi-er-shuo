# ==========================================
# Next.js 15 frontend .dockerignore
# 阻止构建上下文的无关文件进 image,提高构建速度 + 减少 image 体积
# ==========================================

# Version control
.git
.gitignore

# Dependencies (Dockerfile 里重新 npm install)
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store

# Build artifacts
.next
out
*.tsbuildinfo

# Test
coverage
*.lcov
test-results
playwright-report
playwright/.cache
tests
e2e

# Environment files
.env
.env.*
.env.local
.env.*.local

# Logs
*.log

# IDE
.vscode
.idea
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Docker 自引用
Dockerfile
.dockerignore
